# === AWS ===
AWS_REGION=us-east-1
AWS_PROFILE=default

# === Stack configuration (override defaults in settings.yaml) ===
CLAUDESTREET_ENV=dev
CLAUDESTREET_STACK_PREFIX=claudestreet

# === Secrets (stored in AWS Secrets Manager in production) ===
# For local development only — never commit real values
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# === Local development ===
CLAUDESTREET_LOCAL=true
LOG_LEVEL=INFO
